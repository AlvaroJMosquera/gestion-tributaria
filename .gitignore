# ======================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ======================================================
# PYINSTALLER (tu main.spec y builds)
# ======================================================
*.spec
build/
dist/
*.exe

# ======================================================
