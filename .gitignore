# ======================================================
# CREDENCIALES Y CONFIGURACIÓN SENSIBLE
# ======================================================
.env
*.env
.env.local
.env.production

# ======================================================
# ENTORNO VIRTUAL PYTHON
# ======================================================
venv/
.venv/
env/
ENV/

# ======================================================
