# ======================================================
*.sqlite
*.db
Supabase.txt

# ======================================================
# IDEs Y EDITORES
# ======================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ======================================================
# SISTEMA OPERATIVO
# ======================================================
.DS_Store
Thumbs.db
desktop.ini

# ======================================================
# LOGS
